# The backend API base URL. For cpolar penetration, replace this with your cpolar domain.
# Example: https://xxxx.cpolar.top
VITE_API_BASE_URL=http://127.0.0.1:18080
VITE_DEV_PROXY_TARGET=http://127.0.0.1:18080
VITE_CPOLAR_DOMAIN=https://your-cpolar-domain.cpolar.top

# OAuth configuration (update these if using cpolar)
VITE_OAUTH_CLIENT_ID=web-client
VITE_OAUTH_REDIRECT_URI=http://127.0.0.1:18080/callback
VITE_SEARCH_FALLBACK_TIMEOUT=5000
