<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cloud.user.mapper.PermissionMapper">

    <resultMap id="BaseResultMap" type="com.cloud.user.module.entity.Permission">
        <id property="id" column="id"/>
        <result property="permissionName" column="permission_name"/>
        <result property="permissionCode" column="permission_code"/>
        <result property="httpMethod" column="http_method"/>
        <result property="apiPath" column="api_path"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="deleted" column="deleted"/>
        <result property="version" column="version"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,permission_name,permission_code,http_method,api_path,created_at,updated_at,deleted,version
    </sql>
</mapper>
