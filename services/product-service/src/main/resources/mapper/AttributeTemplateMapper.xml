        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cloud.product.mapper.AttributeTemplateMapper">

    <resultMap id="BaseResultMap" type="com.cloud.product.module.entity.AttributeTemplate">
