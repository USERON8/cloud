{
  "info": {
    "_postman_id": "2f2b51b8-ffb3-4cf6-a2a4-2c7b8b3a2b1f",
    "name": "Cloud Shop API Tests",
    "description": "Chain-aligned Postman collection for the Cloud Shop gateway API. The collection follows the current backend routes on main and removes legacy order endpoints that no longer exist.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.environment.set('idempotencyKey', 'idem-' + pm.variables.replaceIn('{{$guid}}'));",
          "pm.environment.set('paymentNoDraft', 'PAY' + pm.variables.replaceIn('{{$timestamp}}'));",
          "pm.environment.set('refundNoDraft', 'REF' + pm.variables.replaceIn('{{$timestamp}}'));"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const contentType = pm.response.headers.get('Content-Type') || '';",
          "if (contentType.includes('application/json')) {",
          "  let body = {};",
          "  try { body = pm.response.json(); } catch (e) {}",
          "  if (body && Object.prototype.hasOwnProperty.call(body, 'code')) {",
          "    pm.test('Response code is successful', function () { pm.expect(body.code).to.eql(200); });",
          "  }",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Auth And Session",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/users/register",
            "auth": {
              "type": "noauth"
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"puser_{{$randomInt}}\",\n  \"password\": \"{{registerPassword}}\",\n  \"phone\": \"{{registerPhone}}\",\n  \"nickname\": \"Postman User\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let body = {}; try { body = pm.response.json(); } catch (e) {}",
                  "if (body && body.data) { if (body.data.id) pm.environment.set('userId', String(body.data.id)); if (body.data.username) pm.environment.set('username', body.data.username); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Validate Current Token",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/tokens/validate"
          }
        },
        {
          "name": "Logout Current Session",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/auth/sessions"
          }
        },
        {
          "name": "Get GitHub Login URL",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/oauth2/github/login-url?redirectPath=/app/home",
            "auth": {
              "type": "noauth"
            }
          }
        },
        {
          "name": "Get OAuth2 Token (Internal Client Credentials)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/oauth2/token",
            "auth": {
              "type": "noauth"
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "grant_type",
                  "value": "client_credentials",
                  "type": "text"
                },
                {
                  "key": "client_id",
                  "value": "{{internalClientId}}",
                  "type": "text"
                },
                {
                  "key": "client_secret",
                  "value": "{{internalClientSecret}}",
                  "type": "text"
                },
                {
                  "key": "scope",
                  "value": "internal",
                  "type": "text"
                }
              ]
            }
          }
        }
      ]
    },
