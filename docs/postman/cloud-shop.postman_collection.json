{
    "info":  {
                 "_postman_id":  "ad37c253-56dc-4a34-a272-1b964551c8c6",
                 "name":  "Cloud Shop API (Gateway)",
                 "description":  "Cloud shop microservices API collection via gateway. Includes auth, v1/v2 business APIs, and key smoke flows.",
                 "schema":  "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
             },
    "item":  [
                 {
                     "name":  "Auth",
                     "item":  [
                                  {
                                      "name":  "Register",
                                      "request":  {
                                                      "method":  "POST",
                                                      "header":  [
                                                                     {
                                                                         "key":  "Content-Type",
                                                                         "value":  "application/json"
                                                                     }
                                                                 ],
                                                      "body":  {
                                                                   "mode":  "raw",
                                                                   "raw":  "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\",\n  \"phone\": \"{{phone}}\",\n  \"nickname\": \"{{nickname}}\",\n  \"userType\": \"USER\"\n}"
                                                               },
                                                      "url":  "{{baseUrl}}/auth/users/register"
                                                  }
                                  },
                                  {
                                      "name":  "Authorize (Browser Redirect)",
                                      "request":  {
                                                      "method":  "GET",
                                                      "url":  "{{baseUrl}}/oauth2/authorize?response_type=code\u0026client_id={{oauthClientId}}\u0026redirect_uri={{oauthRedirectUri}}\u0026scope={{oauthScope}}\u0026state={{oauthState}}\u0026code_challenge={{oauthCodeChallenge}}\u0026code_challenge_method=S256",
                                                      "description":  "Open this request in a browser-capable client. The authorization server will authenticate the user, then redirect to redirect_uri with code and state."
                                                  }
                                  },
                                  {
                                      "name":  "Exchange Authorization Code",
                                      "request":  {
                                                      "method":  "POST",
                                                      "header":  [
                                                                     {
                                                                         "key":  "Content-Type",
                                                                         "value":  "application/x-www-form-urlencoded"
                                                                     }
                                                                 ],
                                                      "body":  {
                                                                   "mode":  "urlencoded",
                                                                   "urlencoded":  [
                                                                                      {
                                                                                          "key":  "grant_type",
                                                                                          "value":  "authorization_code",
                                                                                          "type":  "text"
                                                                                      },
                                                                                      {
                                                                                          "key":  "client_id",
                                                                                          "value":  "{{oauthClientId}}",
                                                                                          "type":  "text"
                                                                                      },
                                                                                      {
                                                                                          "key":  "code",
                                                                                          "value":  "{{oauthCode}}",
                                                                                          "type":  "text"
                                                                                      },
                                                                                      {
                                                                                          "key":  "redirect_uri",
                                                                                          "value":  "{{oauthRedirectUri}}",
                                                                                          "type":  "text"
                                                                                      },
                                                                                      {
                                                                                          "key":  "code_verifier",
                                                                                          "value":  "{{oauthCodeVerifier}}",
                                                                                          "type":  "text"
                                                                                      }
                                                                                  ]
                                                               },
                                                      "url":  "{{baseUrl}}/oauth2/token"
                                                  }
                                  },
                                  {
                                      "name":  "Refresh Token (Standard Endpoint)",
                                      "request":  {
                                                      "method":  "POST",
                                                      "header":  [
                                                                     {
                                                                         "key":  "Content-Type",
                                                                         "value":  "application/x-www-form-urlencoded"
                                                                     }
                                                                 ],
                                                      "body":  {
                                                                   "mode":  "urlencoded",
                                                                   "urlencoded":  [
                                                                                      {
                                                                                          "key":  "grant_type",
                                                                                          "value":  "refresh_token",
                                                                                          "type":  "text"
                                                                                      },
                                                                                      {
                                                                                          "key":  "client_id",
                                                                                          "value":  "{{oauthClientId}}",
                                                                                          "type":  "text"
                                                                                      },
                                                                                      {
                                                                                          "key":  "refresh_token",
                                                                                          "value":  "{{refreshToken}}",
                                                                                          "type":  "text"
                                                                                      }
                                                                                  ]
                                                               },
                                                      "url":  "{{baseUrl}}/oauth2/token"
                                                  }
                                  },
                                  {
                                      "name":  "Validate Token",
                                      "request":  {
                                                      "method":  "GET",
                                                      "header":  [
                                                                     {
                                                                         "key":  "Authorization",
                                                                         "value":  "Bearer {{accessToken}}"
                                                                     }
                                                                 ],
                                                      "url":  "{{baseUrl}}/auth/tokens/validate"
                                                  }
                                  },
                                  {
                                      "name":  "Logout",
                                      "request":  {
                                                      "method":  "DELETE",
                                                      "header":  [
                                                                     {
                                                                         "key":  "Authorization",
                                                                         "value":  "Bearer {{accessToken}}"
                                                                     }
                                                                 ],
                                                      "url":  "{{baseUrl}}/auth/sessions"
                                                  }
                                  }
                              ]
                 },
