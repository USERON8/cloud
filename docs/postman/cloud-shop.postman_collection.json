              "mode": "raw",
              "raw": "{\n  \"mainOrderNo\": \"M2026000001\",\n  \"subOrderNo\": \"S2026000001\",\n  \"skuId\": {{skuId}},\n  \"qty\": 1\n}"
            },
            "url": "{{baseUrl}}/api/v2/stocks/reserve"
