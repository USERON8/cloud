                                  {
                                      "name":  "Create Main Order (v2)",
                                      "event":  [
                                                    {
                                                        "listen":  "test",
                                                        "script":  {
                                                                       "exec":  [
                                                                                    "const res = pm.response.json();",
                                                                                    "const id = res?.data?.id;",
                                                                                    "if (id) pm.collectionVariables.set(\u0027mainOrderId\u0027, String(id));"
                                                                                ],
                                                                       "type":  "text/javascript"
                                                                   }
                                                    }
                                                ],
                                      "request":  {
                                                      "method":  "POST",
                                                      "header":  [
                                                                     {
                                                                         "key":  "Authorization",
                                                                         "value":  "Bearer {{accessToken}}"
                                                                     },
                                                                     {
                                                                         "key":  "Content-Type",
                                                                         "value":  "application/json"
                                                                     }
                                                                 ],
                                                      "body":  {
                                                                   "mode":  "raw",
                                                                   "raw":  "{\n  \"userId\": {{userId}},\n  \"totalAmount\": 299.00,\n  \"payableAmount\": 299.00,\n  \"remark\": \"postman v2 main order\",\n  \"idempotencyKey\": \"idem-{{$timestamp}}\"\n}"
                                                               },
                                                      "url":  "{{baseUrl}}/api/v2/order-main"
                                                  }
                                  },
                                  {
                                      "name":  "List Sub Orders (v2)",
                                      "event":  [
                                                    {
                                                        "listen":  "test",
                                                        "script":  {
                                                                       "exec":  [
                                                                                    "const res = pm.response.json();",
                                                                                    "const first = Array.isArray(res?.data) ? res.data[0] : null;",
                                                                                    "if (first \u0026\u0026 first.id) pm.collectionVariables.set(\u0027subOrderId\u0027, String(first.id));"
                                                                                ],
                                                                       "type":  "text/javascript"
                                                                   }
                                                    }
                                                ],
                                      "request":  {
                                                      "method":  "GET",
                                                      "header":  [
                                                                     {
                                                                         "key":  "Authorization",
                                                                         "value":  "Bearer {{accessToken}}"
                                                                     }
                                                                 ],
                                                      "url":  "{{baseUrl}}/api/v2/order-main/{{mainOrderId}}/sub-orders"
                                                  }
                                  },
