    {
      "name": "Orders And After-Sale",
      "item": [
        {
          "name": "Create Order (Direct Buy)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/orders",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Idempotency-Key",
                "value": "{{idempotencyKey}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"spuId\": \"{{spuId}}\",\n  \"skuId\": \"{{skuId}}\",\n  \"quantity\": 1,\n  \"remark\": \"postman direct buy\",\n  \"receiverName\": \"{{receiverName}}\",\n  \"receiverPhone\": \"{{receiverPhone}}\",\n  \"receiverAddress\": \"{{receiverAddress}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let body = {}; try { body = pm.response.json(); } catch (e) {}",
                  "if (body && body.data && body.data.mainOrder) { if (body.data.mainOrder.id) pm.environment.set('mainOrderId', String(body.data.mainOrder.id)); if (body.data.mainOrder.mainOrderNo) pm.environment.set('mainOrderNo', body.data.mainOrder.mainOrderNo); }",
                  "if (body && body.data && body.data.subOrders && body.data.subOrders.length > 0) { const sub = body.data.subOrders[0].subOrder; if (sub && sub.id) pm.environment.set('subOrderId', String(sub.id)); if (sub && sub.subOrderNo) pm.environment.set('subOrderNo', sub.subOrderNo); }"
                ]
              }
            }
          ]
        },
        {
          "name": "List Orders",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/orders?page=1&size=20&userId={{userId}}"
          }
        },
        {
          "name": "Get Order Detail",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/orders/{{mainOrderId}}"
          }
        },
        {
          "name": "Cancel Order",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/orders/{{mainOrderId}}/cancel?cancelReason=postman-cancel"
          }
        },
        {
          "name": "Apply After-Sale",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/orders/after-sales",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mainOrderId\": \"{{mainOrderId}}\",\n  \"subOrderId\": \"{{subOrderId}}\",\n  \"userId\": \"{{userId}}\",\n  \"merchantId\": \"{{merchantId}}\",\n  \"afterSaleType\": \"REFUND\",\n  \"reason\": \"quality issue\",\n  \"description\": \"box damaged\",\n  \"applyAmount\": 1.0\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let body = {}; try { body = pm.response.json(); } catch (e) {}",
                  "if (body && body.data) { if (body.data.id) pm.environment.set('afterSaleId', String(body.data.id)); if (body.data.afterSaleNo) pm.environment.set('afterSaleNo', body.data.afterSaleNo); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Cancel After-Sale",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/orders/after-sales/{{afterSaleId}}/actions/CANCEL?remark=postman"
          }
        }
      ]
    },
    {
      "name": "Payments And Checkout",
      "item": [
        {
          "name": "Create Payment Order",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/payments/orders",
            "description": "Regular user payment creation is owner-bound. The amount must match the payable amount of the order.",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"paymentNo\": \"{{paymentNoDraft}}\",\n  \"mainOrderNo\": \"{{mainOrderNo}}\",\n  \"subOrderNo\": \"{{subOrderNo}}\",\n  \"userId\": \"{{userId}}\",\n  \"amount\": 1.0,\n  \"channel\": \"ALIPAY\",\n  \"idempotencyKey\": \"{{idempotencyKey}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let body = {}; try { body = pm.response.json(); } catch (e) {}",
                  "if (body && body.data) pm.environment.set('paymentId', String(body.data));",
                  "pm.environment.set('paymentNo', pm.environment.get('paymentNoDraft'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Payment Order By Number",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/payments/orders/{{paymentNo}}"
          }
        },
        {
          "name": "Get Payment Order By Order Pair",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/payments/orders/by-order?mainOrderNo={{mainOrderNo}}&subOrderNo={{subOrderNo}}"
          }
        },
        {
          "name": "Create Checkout Session",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/payments/orders/{{paymentNo}}/checkout-session"
          }
        },
        {
          "name": "Get Payment Status",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/payments/orders/{{paymentNo}}/status"
          }
        },
        {
          "name": "Get Refund",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/payments/refunds/{{refundNo}}"
          }
        },
        {
          "name": "Create Refund",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/payments/refunds",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refundNo\": \"{{refundNoDraft}}\",\n  \"paymentNo\": \"{{paymentNo}}\",\n  \"afterSaleNo\": \"{{afterSaleNo}}\",\n  \"refundAmount\": 1.0,\n  \"reason\": \"quality issue\",\n  \"idempotencyKey\": \"{{idempotencyKey}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let body = {}; try { body = pm.response.json(); } catch (e) {}",
                  "if (body && body.data) { pm.environment.set('refundId', String(body.data)); pm.environment.set('refundNo', pm.environment.get('refundNoDraft')); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Alipay Notify Callback",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/payment/alipay/notify",
            "description": "This request documents the external callback shape. It will only succeed with a valid provider signature in a real environment.",
            "auth": {
              "type": "noauth"
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "out_trade_no",
                  "value": "{{paymentNo}}",
                  "type": "text"
                },
                {
                  "key": "trade_no",
                  "value": "ALI-TXN-{{$timestamp}}",
                  "type": "text"
                },
                {
                  "key": "trade_status",
                  "value": "TRADE_SUCCESS",
                  "type": "text"
                },
                {
                  "key": "total_amount",
                  "value": "1.00",
                  "type": "text"
                },
                {
                  "key": "gmt_payment",
                  "value": "2026-03-21 12:00:00",
                  "type": "text"
                },
                {
                  "key": "sign_type",
                  "value": "RSA2",
                  "type": "text"
                },
                {
                  "key": "sign",
                  "value": "mock-signature",
                  "type": "text"
                }
              ]
            }
          }
        }
      ]
    },
