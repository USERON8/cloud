            "body": {
              "mode": "raw",
              "raw": "{\n  \"skuId\": {{skuId}},\n  \"warehouseCode\": \"W001\",\n  \"onHandQty\": 100,\n  \"reservedQty\": 0,\n  \"salableQty\": 100\n}"
            },
